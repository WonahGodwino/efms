{
  "name": "mapsi-efms-backend",
  "version": "1.0.0",
  "description": "Mapsi Group Enterprise Financial Management System - Backend",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "build": "node -e \"console.log('No build step required for mapsi-efms-backend')\"",
    "dev": "nodemon src/app.js",
    "debug": "node --inspect src/app.js",
    "prod": "NODE_ENV=production node src/app.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest-e2e.config.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "prisma db seed",
    "studio": "prisma studio",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "bwip-js": "^4.8.0",
    "canvas": "^3.2.1",
    "chart.js": "^4.5.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-fileupload": "^1.4.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.3.1",
    "handlebars": "^4.7.7",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^3.0.0",
    "redis": "^4.6.5",
    "sharp": "^0.32.1",
    "swagger-ui-express": "^4.6.3",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "eslint": "^8.42.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^2.8.8",
    "prisma": "^5.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
